{
  "name": "revoke.cash",
  "description": "Take back control of your wallet and stay safe by revoking token approvals you granted on Ethereum and over 100 other networks.",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace web dev",
    "build": "yarn workspace web build",
    "build:preview": "yarn workspace web build:preview",
    "build:images": "yarn workspace web build:images",
    "analyze": "yarn workspace web analyze",
    "start": "yarn workspace web start",
    "trim-sitemap": "yarn workspace web trim-sitemap",
    "lint": "biome check .",
    "lint:fix": "yarn lint --write",
    "lint:staged": "yarn lint --error-on-warnings --no-errors-on-unmatched --staged .",
    "lint:checksums": "yarn workspace web lint:checksums",
    "typecheck": "yarn workspace @revoke.cash/core typecheck && yarn workspace web typecheck && yarn workspace @revoke.cash/approval-monitor typecheck",
    "test": "yarn workspace web test",
    "test:mocha": "yarn workspace web test:mocha",
    "test:cypress": "yarn workspace web test:cypress",
    "translations:update": "yarn workspace web translations:update && yarn lint:fix",
    "translations:update:md": "yarn workspace web translations:update:md",
    "exploits:update": "yarn workspace web exploits:update",
    "tsx": "yarn workspace web tsx",
    "db:generate": "yarn workspace @revoke.cash/core db:generate",
    "db:migrate": "yarn workspace @revoke.cash/core db:migrate",
    "db:push": "yarn workspace @revoke.cash/core db:push",
    "db:studio": "yarn workspace @revoke.cash/core db:studio",
    "db:drop": "yarn workspace @revoke.cash/core db:drop",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@lavamoat/allow-scripts": "^3.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "packageManager": "yarn@4.15.0",
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "lavamoat": {
    "allowScripts": {
      "$root$": true,
      "@abstract-foundation/agw-react>secp256k1": false,
      "@biomejs/biome": true,
      "@nestjs/core": false,
      "@tailwindcss/postcss>@tailwindcss/oxide": false,
      "@vercel/speed-insights": false,
      "@walletconnect/ethereum-provider>@reown/appkit": true,
      "cypress": true,
      "next>sharp": true,
      "next-intl>@parcel/watcher": false,
      "next-intl>@swc/core": true,
      "tsx>esbuild": true,
      "viem>ws>bufferutil": true,
      "viem>ws>utf-8-validate": true,
      "drizzle-kit>@esbuild-kit/esm-loader>@esbuild-kit/core-utils>esbuild": false,
      "drizzle-kit>esbuild": false,
      "@nestjs/schedule>cron>@types/luxon": false,
      "bullmq>msgpackr>msgpackr-extract": false
    }
  },
  "resolutions": {
    "rate-limiter-flexible@^5.0.0": "patch:rate-limiter-flexible@npm%3A5.0.0#./.yarn/patches/rate-limiter-flexible-npm-5.0.0-9e3dae9215.patch"
  }
}
