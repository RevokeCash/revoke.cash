{
  "name": "@revoke.cash/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./allowances": "./lib/allowances/index.ts",
    "./chains": "./lib/chains/index.ts",
    "./delegations": "./lib/delegations/index.ts",
    "./events": "./lib/events/index.ts",
    "./events/getters": "./lib/events/getters/index.ts",
    "./events/providers": "./lib/events/providers/index.ts",
    "./whois": "./lib/whois/index.ts",
    "./*": "./lib/*.ts"
  },
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "typecheck": "tsc --noEmit",
    "db:generate": "yarn env drizzle-kit generate",
    "db:migrate": "yarn env drizzle-kit migrate",
    "db:push": "yarn env drizzle-kit push",
    "db:studio": "yarn env drizzle-kit studio",
    "db:drop": "yarn env drizzle-kit drop"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.4.0",
    "@metamask/smart-accounts-kit": "^1.6.0",
    "@neondatabase/serverless": "^1.1.0",
    "@revoke.cash/chains": "^79.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "dexie": "^4.4.4",
    "drizzle-orm": "^0.45.2",
    "ky": "^2.0.2",
    "md5": "^2.3.0",
    "p-queue": "^9.3.0",
    "viem": "^2.54.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.0.0",
    "@types/md5": "^2.3.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  },
  "lavamoat": {
    "allowScripts": {
      "drizzle-kit>@esbuild-kit/esm-loader>@esbuild-kit/core-utils>esbuild#0.18.20": false,
      "drizzle-kit>esbuild#0.25.12": false,
      "tsx>esbuild#0.28.1": true,
      "viem>ws>bufferutil#4.0.9": true,
      "viem>ws>utf-8-validate#5.0.10": true
    }
  }
}
