{
  "name": "@revoke.cash/auto-revoke-executor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "swc-node": "node --require @swc-node/register",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "ceremony": "yarn env tsx scripts/ceremony.ts",
    "killswitch": "yarn env tsx scripts/killswitch.ts",
    "dev": "PORT=3003 yarn env yarn swc-node --watch src/main.ts",
    "start": "yarn env yarn swc-node src/main.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@revoke.cash/backend": "workspace:*",
    "@revoke.cash/core": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "bullmq": "^5.79.2",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "viem": "^2.54.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.0.0",
    "@ledgerhq/context-module": "^2.1.0",
    "@ledgerhq/device-management-kit": "^1.7.1",
    "@ledgerhq/device-signer-kit-ethereum": "^1.16.0",
    "@ledgerhq/device-transport-kit-node-hid": "^1.0.1",
    "@types/node": "^22.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.5"
  },
  "lavamoat": {
    "allowScripts": {
      "@ledgerhq/device-transport-kit-node-hid>node-hid#3.3.0": false,
      "@ledgerhq/device-transport-kit-node-hid>usb#2.18.0": false,
      "@swc/core#1.15.43": true,
      "bullmq>msgpackr>msgpackr-extract#3.0.4": false,
      "tsx>esbuild#0.28.1": true,
      "viem>ws>bufferutil#4.0.9": true,
      "viem>ws>utf-8-validate#5.0.10": true
    }
  }
}
