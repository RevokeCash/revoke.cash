{
  "name": "web",
  "description": "Take back control of your wallet and stay safe by revoking token approvals you granted on Ethereum and over 100 other networks.",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "dev": "yarn env next dev",
    "build": "yarn env next build && yarn env next-sitemap",
    "build:preview": "yarn env next build --profile && yarn env next-sitemap",
    "trim-sitemap": "sed 's,<urlset.*,<urlset xmlns=\"https://www.sitemaps.org/schemas/sitemap/0.9\" xmlns:xhtml=\"http://www.w3.org/1999/xhtml\">,g' public/sitemap.xml",
    "start": "yarn env next start",
    "analyze": "ANALYZE=true yarn build",
    "typecheck": "tsc --noEmit",
    "lint:checksums": "yarn tsx scripts/lint-checksums.ts && git rm -r --cached -q data && git add --all data",
    "translations:update": "localazy upload && localazy download",
    "translations:update:md": "localazy upload -k localazy.content.keys.json -c localazy.content.json && localazy download -k localazy.content.keys.json -c localazy.content.json && yarn tsx scripts/remove-untranslated-markdown-files.ts",
    "test": "yarn test:mocha && yarn test:cypress",
    "test:cypress": "cypress run",
    "test:mocha": "yarn env mocha test/**/*.test.ts --",
    "exploits:update": "yarn tsx scripts/update-exploits.ts ../../../approval-exploit-list ../../../whois",
    "tsx": "yarn env tsx"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "^1.12.3",
    "@abstract-foundation/agw-react": "^1.13.0",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@farcaster/miniapp-wagmi-connector": "^2.0.0",
    "@floating-ui/react": "^0.27.19",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@metamask/smart-accounts-kit": "^1.6.0",
    "@privy-io/cross-app-connect": "^0.5.15",
    "@revoke.cash/chains": "^79.0.0",
    "@revoke.cash/core": "workspace:*",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "@worldcoin/minikit-js": "2.0.3",
    "crisp-sdk-web": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "iron-session": "^8.0.4",
    "mixpanel-browser": "^2.70.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.1",
    "nextjs-toploader": "^3.9.17",
    "nprogress": "^0.2.0",
    "p-queue": "^9.3.0",
    "rate-limiter-flexible": "^11.2.0",
    "react": "^19.2.7",
    "react-async-hook": "^4.0.0",
    "react-dom": "^19.2.7",
    "react-lite-youtube-embed": "^3.6.0",
    "react-markdown": "^10.1.0",
    "react-sticky-box": "^2.0.5",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.1.0",
    "reading-time-estimator": "^2.9.0",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "timeago-react": "^3.0.7",
    "timeago.js": "^4.0.2",
    "use-local-storage": "^3.0.0",
    "viem": "^2.54.1",
    "wagmi": "^3.6.21",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cypress/grep": "^6.0.2",
    "@dotenvx/dotenvx": "^2.0.0",
    "@localazy/cli": "^2.0.11",
    "@next/bundle-analyzer": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^22.20.0",
    "@types/nprogress": "^0.2.3",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chai": "^6.2.2",
    "cypress": "^15.18.0",
    "fast-csv": "^5.0.7",
    "mocha": "^11.7.6",
    "next-sitemap": "^4.2.3",
    "pdfkit": "^0.19.1",
    "postcss": "^8.5.16",
    "tailwindcss": "4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "walkdir": "^0.4.1"
  },
  "mocha": {
    "node-option": [
      "import=tsx"
    ],
    "timeout": 30000,
    "exit": true
  },
  "lavamoat": {
    "allowScripts": {
      "@walletconnect/ethereum-provider>@reown/appkit#1.8.19": true,
      "cypress#15.18.0": true,
      "next-intl>@parcel/watcher#2.5.6": false,
      "next>sharp#0.34.5": true,
      "tsx>esbuild#0.28.1": true,
      "viem>ws>bufferutil#4.0.9": true,
      "viem>ws>utf-8-validate#5.0.10": true,
      "next-intl>@swc/core#1.15.43": true
    }
  }
}
