{
  "name": "web",
  "description": "Take back control of your wallet and stay safe by revoking token approvals you granted on Ethereum and over 100 other networks.",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "dev": "yarn env next dev",
    "build": "yarn env next build && yarn env next-sitemap",
    "build:preview": "yarn env next build --profile && yarn env next-sitemap",
    "trim-sitemap": "sed 's,<urlset.*,<urlset xmlns=\"https://www.sitemaps.org/schemas/sitemap/0.9\" xmlns:xhtml=\"http://www.w3.org/1999/xhtml\">,g' public/sitemap.xml",
    "start": "yarn env next start",
    "analyze": "ANALYZE=true yarn build",
    "typecheck": "tsc --noEmit",
    "lint:checksums": "yarn tsx scripts/lint-checksums.ts && git rm -r --cached -q data && git add --all data",
    "translations:update": "localazy upload && localazy download",
    "translations:update:md": "localazy upload -k localazy.content.keys.json -c localazy.content.json && localazy download -k localazy.content.keys.json -c localazy.content.json && yarn tsx scripts/remove-untranslated-markdown-files.ts",
    "test": "yarn test:mocha && yarn test:cypress",
    "test:cypress": "cypress run",
    "test:mocha": "yarn env mocha test/**/*.test.ts --",
    "exploits:update": "yarn tsx scripts/update-exploits.ts ../../../approval-exploit-list ../../../whois",
    "tsx": "yarn env tsx"
  },
  "dependencies": {
    "@abstract-foundation/agw-client": "^1.10.0",
    "@abstract-foundation/agw-react": "^1.10.0",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@farcaster/miniapp-sdk": "^0.2.3",
    "@farcaster/miniapp-wagmi-connector": "^1.1.1",
    "@floating-ui/react": "^0.27.17",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@metamask/smart-accounts-kit": "^1.6.0",
    "@privy-io/cross-app-connect": "^0.2.3",
    "@revoke.cash/chains": "^79.0.0",
    "@revoke.cash/core": "workspace:*",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "^9.1.0",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "^1.36.2",
    "@vercel/speed-insights": "^1.3.1",
    "@walletconnect/ethereum-provider": "^2.23.4",
    "@worldcoin/minikit-js": "2.0.0-dev.0",
    "crisp-sdk-web": "^1.0.27",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "iron-session": "^8.0.4",
    "ky": "^1.14.3",
    "mixpanel-browser": "^2.70.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.2",
    "nextjs-toploader": "^3.9.17",
    "p-queue": "^9.1.0",
    "rate-limiter-flexible": "^9.1.1",
    "react": "^19.2.4",
    "react-async-hook": "^4.0.0",
    "react-dom": "^19.2.4",
    "react-lite-youtube-embed": "^3.3.3",
    "react-markdown": "^10.1.0",
    "react-select": "^5.10.2",
    "react-sticky-box": "^2.0.5",
    "react-syntax-highlighter": "^15.6.6",
    "react-toastify": "^11.0.5",
    "reading-time-estimator": "^2.1.1",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^0.4.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "timeago-react": "^3.0.7",
    "timeago.js": "^4.0.2",
    "use-local-storage": "^3.0.0",
    "viem": "^2.45.2",
    "wagmi": "^3.4.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cypress/grep": "^6.0.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "@localazy/cli": "^2.0.8",
    "@next/bundle-analyzer": "^16.1.6",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^22.19.10",
    "@types/nprogress": "^0.2.3",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/request-ip": "^0.0.41",
    "chai": "^6.2.2",
    "cypress": "^15.10.0",
    "fast-csv": "^5.0.5",
    "glob": "^13.0.1",
    "mocha": "^11.7.5",
    "next-sitemap": "^4.2.3",
    "pdfkit": "^0.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "walkdir": "^0.4.1"
  },
  "mocha": {
    "node-option": [
      "import=tsx"
    ],
    "timeout": 30000,
    "exit": true
  }
}
