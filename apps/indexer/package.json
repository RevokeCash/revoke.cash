{
  "name": "@revoke.cash/indexer",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "swc-node": "node --require @swc-node/register",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "dev:manager": "IS_MANAGER=true PORT=3001 yarn env yarn swc-node --watch src/main.ts",
    "dev:worker": "PORT=3002 yarn env yarn swc-node --watch src/main.ts",
    "start:manager": "IS_MANAGER=true yarn swc-node src/main.ts",
    "start:worker": "yarn swc-node src/main.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@bull-board/api": "^8.1.2",
    "@bull-board/express": "^8.1.2",
    "@bull-board/nestjs": "^8.1.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@revoke.cash/backend": "workspace:*",
    "@revoke.cash/core": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "bullmq": "^5.79.3",
    "express-basic-auth": "^1.2.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.3.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.1",
    "pino-pretty": "^13.1.3"
  },
  "lavamoat": {
    "allowScripts": {
      "@revoke.cash/core>viem>ws>bufferutil#4.0.9": true,
      "@revoke.cash/core>viem>ws>utf-8-validate#5.0.10": true,
      "@swc/core#1.15.43": true,
      "bullmq>msgpackr>msgpackr-extract#3.0.4": false
    }
  }
}
