{
  "name": "@revoke.cash/indexer",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "env": "dotenvx run -f ../../.env --",
    "swc-node": "node --require @swc-node/register",
    "allow-scripts": "cd ../.. && yarn run allow-scripts",
    "dev:manager": "IS_MANAGER=true PORT=3001 yarn env yarn swc-node --watch src/main.ts",
    "dev:worker": "PORT=3002 yarn env yarn swc-node --watch src/main.ts",
    "start:manager": "IS_MANAGER=true yarn swc-node src/main.ts",
    "start:worker": "yarn swc-node src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bull-board/api": "^6.7.7",
    "@bull-board/express": "^6.7.7",
    "@bull-board/nestjs": "^6.7.7",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/terminus": "^10.3.0",
    "@revoke.cash/core": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.34.0",
    "express-basic-auth": "^1.2.1",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "prometheus-remote-write": "^0.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0"
  }
}
